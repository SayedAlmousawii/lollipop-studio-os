generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  RECEPTIONIST
  RESERVATION
  PHOTOGRAPHER
  EDITOR
  ACCOUNTANT
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CANCELLED
  NO_SHOW
}

enum OrderStatus {
  ACTIVE
  WAITING_SELECTION
  SELECTION_COMPLETED
  EDITING
  PRODUCTION
  READY
  DELIVERED
  CANCELLED
}

enum OrderSelectionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum OrderEditingStatus {
  NOT_STARTED
  ASSIGNED
  IN_PROGRESS
  REVISION_REQUESTED
  AWAITING_APPROVAL
  APPROVED
  COMPLETED
}

enum OrderProductionStatus {
  NOT_STARTED
  WAITING_FOR_EDITING
  IN_PROGRESS
  WAITING_FOR_VENDOR
  READY_FOR_PICKUP
  COMPLETED
}

enum OrderProductionSectionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum OrderDeliveryStatus {
  NOT_READY
  READY_FOR_PICKUP
  CUSTOMER_NOTIFIED
  PICKED_UP
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  CLOSED
}

enum InvoiceType {
  DEPOSIT
  FINAL
  ADJUSTMENT
  REFUND
  CREDIT_NOTE
  SALE
}

enum InvoiceLineType {
  PACKAGE_BASE
  BUNDLE_ADJUSTMENT
  PACKAGE_UPGRADE
  ADD_ON
  EXTRA_PHOTOS
  MANUAL_DISCOUNT
  MANUAL_SURCHARGE
}

enum OrderEntityKind {
  ADDON
  UPGRADE
  EXTRA_PHOTO
  PACKAGE_TIER_UPGRADE
}

enum PaymentMethod {
  CASH
  KNET
  LINK
}

enum PaymentType {
  DEPOSIT
  FINAL
  ADJUSTMENT
  REFUND
  UPGRADE
  ADDON
  OTHER
}

enum PaymentDirection {
  IN
  OUT
}

enum ProductCategory {
  ALBUM
  CANVAS
  DIGITAL
  PRINT
  FRAME
  USB
  OTHER
}

enum MediaType {
  DIGITAL
  PRINT
}

enum OrderActivityType {
  ORDER_CREATED
  PACKAGE_CHANGED
  ORDER_PACKAGE_ADDED
  ORDER_PACKAGE_LINE_CHANGED
  ORDER_PACKAGE_EXTRAS_CHANGED
  ADD_ON_CHANGED
  PAYMENT_RECEIVED
  INVOICE_ADJUSTED
  SELECTION_UPDATED
  SELECTION_COMPLETED
  EDITOR_ASSIGNED
  EDITING_STATUS_CHANGED
  PRODUCTION_STATUS_CHANGED
  DELIVERY_STATUS_CHANGED
  ORDER_COMPLETED
  NOTE_ADDED
  GUARD_BLOCKED
}

enum AuditEntityType {
  INVOICE
  PAYMENT
  ORDER
  BOOKING
  FINANCIAL_CASE
  CREDIT_NOTE
  REFUND
}

enum AuditAction {
  INVOICE_LOCKED
  INVOICE_TOTAL_MUTATED
  PAYMENT_RECORDED
  PAYMENT_REFUNDED
  CREDIT_NOTE_ISSUED
  ADJUSTMENT_ISSUED
  REFUND_ISSUED
  BOOKING_CONFIRMED
  BOOKING_NO_SHOW
  ORDER_LOCKED_FIELD_MUTATED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String?  @unique
  name      String
  email     String   @unique
  role      UserRole @default(RECEPTIONIST)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedBookings     Booking[]             @relation("AssignedPhotographer")
  assignedJobs         Job[]                 @relation("JobAssignedPhotographer")
  assignedEditingJobs  EditingJob[]          @relation("AssignedEditor")
  orderActivities      OrderActivity[]
  auditLogs            AuditLog[]
  deliveryCompletions  Order[]               @relation("DeliveryCompletedBy")
  documentApplications DocumentApplication[]

  @@map("users")
}

model Customer {
  id        String         @id @default(cuid())
  name      String
  phone     String         @unique
  status    CustomerStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  children       Child[]
  jobs           Job[]
  bookings       Booking[]
  orders         Order[]
  invoices       Invoice[]
  financialCases FinancialCase[]

  @@map("customers")
}

model FinancialCase {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  customerId String
  jobId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  booking  Booking   @relation(fields: [bookingId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  job      Job?      @relation(fields: [jobId], references: [id])
  invoices Invoice[]
  payments Payment[]

  @@index([customerId])
  @@index([jobId])
  @@map("financial_cases")
}

model Job {
  id                     String   @id @default(cuid())
  jobNumber              String   @unique
  customerId             String
  assignedPhotographerId String?
  socialMediaConsent     Boolean?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  customer             Customer        @relation(fields: [customerId], references: [id])
  assignedPhotographer User?           @relation("JobAssignedPhotographer", fields: [assignedPhotographerId], references: [id])
  booking              Booking?
  order                Order?
  editingJob           EditingJob?
  productionJob        ProductionJob?
  invoices             Invoice[]
  payments             Payment[]
  financialCases       FinancialCase[]

  @@unique([id, customerId])
  @@index([customerId])
  @@index([assignedPhotographerId])
  @@map("jobs")
}

model Child {
  id          String    @id @default(cuid())
  name        String
  dateOfBirth DateTime?
  customerId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("children")
}

model Package {
  id               String  @id @default(cuid())
  name             String
  price            Decimal @db.Decimal(10, 3)
  photoCount       Int
  packageFamilyId  String
  durationMinutes  Int     @default(60)
  description      String?
  isActive         Boolean @default(true)
  bundleAdjustment Decimal @default(0) @db.Decimal(10, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items           PackageItem[]
  packageFamily   PackageFamily    @relation(fields: [packageFamilyId], references: [id])
  bookingPackages BookingPackage[]
  orderPackages   OrderPackage[]

  @@index([packageFamilyId, isActive])
  @@map("packages")
}

model Product {
  id                   String          @id @default(cuid())
  name                 String
  category             ProductCategory
  canonicalPrice       Decimal         @db.Decimal(10, 3)
  description          String?
  isActive             Boolean         @default(true)
  isPackageDeliverable Boolean         @default(true)
  isAddOn              Boolean         @default(false)
  sortOrder            Int             @default(0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  packageItems PackageItem[]
  orderAddOns  OrderAddOn[]

  @@index([category, isActive])
  @@index([isAddOn, isActive, sortOrder])
  @@map("products")
}

model PackageItem {
  id            String   @id @default(cuid())
  packageId     String
  productId     String
  quantity      Int      @default(1)
  priceSnapshot Decimal  @db.Decimal(10, 3)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  orderUpgrades OrderPackageItemUpgrade[]

  @@unique([packageId, productId])
  @@index([packageId])
  @@index([productId])
  @@map("package_items")
}

model StudioDepartment {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings     Booking[]
  sessionTypes SessionType[]

  @@map("studio_departments")
}

model SessionType {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  departmentId String
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department        StudioDepartment               @relation(fields: [departmentId], references: [id])
  packageFamilies   PackageFamily[]
  extraPhotoPricing SessionTypeExtraPhotoPricing[]
  bookingPackages   BookingPackage[]
  orderPackages     OrderPackage[]

  @@index([departmentId, isActive, sortOrder])
  @@map("session_types")
}

model SessionTypeExtraPhotoPricing {
  id            String    @id @default(cuid())
  sessionTypeId String
  mediaType     MediaType
  unitPrice     Decimal   @db.Decimal(10, 3)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessionType SessionType @relation(fields: [sessionTypeId], references: [id], onDelete: Cascade)

  @@unique([sessionTypeId, mediaType])
  @@index([sessionTypeId])
  @@map("session_type_extra_photo_pricing")
}

model PackageFamily {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  sessionTypeId String
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessionType SessionType @relation(fields: [sessionTypeId], references: [id])
  packages    Package[]

  @@index([sessionTypeId, isActive, sortOrder])
  @@map("package_families")
}

model BookingPackage {
  id            String   @id @default(cuid())
  bookingId     String
  packageId     String
  sessionTypeId String
  quantity      Int      @default(1)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking     Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  package     Package     @relation(fields: [packageId], references: [id])
  sessionType SessionType @relation(fields: [sessionTypeId], references: [id])

  @@unique([bookingId, packageId])
  @@index([bookingId, sortOrder])
  @@index([packageId])
  @@index([sessionTypeId])
  @@map("booking_packages")
}

model Booking {
  id                     String        @id @default(cuid())
  publicId               String?       @unique
  jobNumber              String?       @unique
  jobId                  String?       @unique
  customerId             String
  sessionDate            DateTime
  sessionTime            String
  departmentId           String
  status                 BookingStatus @default(PENDING)
  assignedPhotographerId String?
  notes                  String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  job                  Job?             @relation(fields: [jobId], references: [id])
  customer             Customer         @relation(fields: [customerId], references: [id])
  department           StudioDepartment @relation(fields: [departmentId], references: [id])
  assignedPhotographer User?            @relation("AssignedPhotographer", fields: [assignedPhotographerId], references: [id])
  order                Order?
  themes               BookingTheme[]
  invoices             Invoice[]
  financialCase        FinancialCase?
  packages             BookingPackage[]

  @@index([departmentId])
  @@map("bookings")
}

model BookingTheme {
  id        String   @id @default(cuid())
  bookingId String
  themeName String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_themes")
}

model Order {
  id                     String               @id @default(cuid())
  publicId               String               @unique
  jobNumber              String
  jobId                  String               @unique
  bookingId              String               @unique
  // Intentional denormalization: duplicates Booking.customerId to allow direct
  // customer-scoped queries on orders without joining through bookings.
  customerId             String
  selectedPhotoCount     Int?
  addOns                 Json                 @default("[]")
  status                 OrderStatus          @default(ACTIVE)
  selectionStatus        OrderSelectionStatus @default(PENDING)
  deliveryStatus         OrderDeliveryStatus  @default(NOT_READY)
  deliveryPreparedAt     DateTime?
  customerNotifiedAt     DateTime?
  pickedUpAt             DateTime?
  deliveryCompletedAt    DateTime?
  deliveryCompletedById  String?
  deliveryCompletedBy    String?
  deliveryPickupNotes    String?
  deliveryOverrideReason String?
  nasFolderPath          String?
  notes                  String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  job                     Job                       @relation(fields: [jobId], references: [id])
  booking                 Booking                   @relation(fields: [bookingId], references: [id])
  customer                Customer                  @relation(fields: [customerId], references: [id])
  deliveryCompletedByUser User?                     @relation("DeliveryCompletedBy", fields: [deliveryCompletedById], references: [id])
  editingJob              EditingJob?
  productionJob           ProductionJob?
  invoices                Invoice[]
  activities              OrderActivity[]
  orderAddOns             OrderAddOn[]
  packageItemUpgrades     OrderPackageItemUpgrade[]
  packages                OrderPackage[]

  @@index([jobNumber])
  @@map("orders")
}

model OrderPackage {
  id                           String   @id @default(cuid())
  orderId                      String
  packageId                    String
  sessionTypeId                String
  originalPackagePriceSnapshot Decimal? @db.Decimal(10, 3)
  finalPackagePriceSnapshot    Decimal? @db.Decimal(10, 3)
  selectedPhotoCount           Int?
  extraDigitalCount            Int      @default(0)
  extraPrintCount              Int      @default(0)
  sortOrder                    Int      @default(0)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  order               Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  package             Package                   @relation(fields: [packageId], references: [id])
  sessionType         SessionType               @relation(fields: [sessionTypeId], references: [id])
  orderAddOns         OrderAddOn[]
  packageItemUpgrades OrderPackageItemUpgrade[]

  @@index([orderId, sortOrder])
  @@index([packageId])
  @@index([sessionTypeId])
  @@map("order_packages")
}

model EditingJob {
  id                           String             @id @default(cuid())
  jobId                        String             @unique
  orderId                      String             @unique
  assignedEditorId             String?
  status                       OrderEditingStatus @default(NOT_STARTED)
  editedPhotoCount             Int                @default(0)
  revisionCount                Int                @default(0)
  editingAssignedAt            DateTime?
  editingStartedAt             DateTime?
  editingCompletedAt           DateTime?
  customerApprovedAt           DateTime?
  sentToProductionAt           DateTime?
  estimatedEditingCompletionAt DateTime?
  notes                        String?
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt

  job            Job   @relation(fields: [jobId], references: [id])
  order          Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedEditor User? @relation("AssignedEditor", fields: [assignedEditorId], references: [id])

  @@index([jobId])
  @@index([assignedEditorId])
  @@map("editing_jobs")
}

model ProductionJob {
  id                  String                       @id @default(cuid())
  jobId               String                       @unique
  orderId             String                       @unique
  status              OrderProductionStatus        @default(NOT_STARTED)
  albumDesignStatus   OrderProductionSectionStatus @default(NOT_STARTED)
  printingStatus      OrderProductionSectionStatus @default(NOT_STARTED)
  assemblyStatus      OrderProductionSectionStatus @default(NOT_STARTED)
  vendorStatus        OrderProductionSectionStatus @default(NOT_STARTED)
  framedPrintsStatus  OrderProductionSectionStatus @default(NOT_STARTED)
  finalStatus         OrderProductionSectionStatus @default(NOT_STARTED)
  productionStartedAt DateTime?
  readyForPickupAt    DateTime?
  completedAt         DateTime?
  vendorName          String?
  notes               String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  job   Job   @relation(fields: [jobId], references: [id])
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("production_jobs")
}

model OrderActivity {
  id          String            @id @default(cuid())
  orderId     String
  userId      String?
  type        OrderActivityType
  title       String
  description String?
  metadata    Json              @default("{}")
  createdAt   DateTime          @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([type])
  @@map("order_activities")
}

model AuditLog {
  id          String          @id @default(cuid())
  actorUserId String
  entityType  AuditEntityType
  entityId    String
  action      AuditAction
  before      Json?
  after       Json?
  context     Json            @default("{}")
  occurredAt  DateTime        @default(now())

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId, occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([action, occurredAt])
  @@map("audit_logs")
}

model OrderAddOn {
  id             String   @id @default(cuid())
  orderId        String
  orderPackageId String?
  productId      String
  nameSnapshot   String
  priceSnapshot  Decimal  @db.Decimal(10, 3)
  quantity       Int      @default(1)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderPackage OrderPackage? @relation(fields: [orderPackageId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([orderId, orderPackageId, productId])
  @@index([orderId])
  @@index([orderPackageId])
  @@index([productId])
  @@map("order_add_ons")
}

model OrderPackageItemUpgrade {
  id             String   @id @default(cuid())
  orderId        String
  orderPackageId String
  packageItemId  String
  nameSnapshot   String
  priceSnapshot  Decimal  @db.Decimal(10, 3)
  quantity       Int      @default(1)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderPackage OrderPackage @relation(fields: [orderPackageId], references: [id], onDelete: Cascade)
  packageItem  PackageItem  @relation(fields: [packageItemId], references: [id], onDelete: Restrict)

  @@unique([orderId, orderPackageId, packageItemId])
  @@index([orderId])
  @@index([orderPackageId])
  @@index([packageItemId])
  @@map("order_package_item_upgrades")
}

model Invoice {
  id              String        @id @default(cuid())
  publicId        String        @unique
  financialCaseId String
  invoiceType     InvoiceType
  jobNumber       String?
  jobId           String?
  orderId         String?
  bookingId       String?
  customerId      String
  invoiceSeq      Int           @unique @default(dbgenerated("nextval('\"invoice_number_seq\"'::regclass)"))
  invoiceNumber   String        @unique
  totalAmount     Decimal       @db.Decimal(10, 3)
  paidAmount      Decimal       @default(0) @db.Decimal(10, 3)
  remainingAmount Decimal       @default(0) @db.Decimal(10, 3)
  status          InvoiceStatus @default(DRAFT)
  isLocked        Boolean       @default(false)
  parentInvoiceId String?
  notes           String?
  issuedAt        DateTime?
  closedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  financialCase                FinancialCase         @relation(fields: [financialCaseId], references: [id])
  job                          Job?                  @relation(fields: [jobId], references: [id])
  order                        Order?                @relation(fields: [orderId], references: [id])
  booking                      Booking?              @relation(fields: [bookingId], references: [id])
  customer                     Customer              @relation(fields: [customerId], references: [id])
  parentInvoice                Invoice?              @relation("InvoiceAdjustments", fields: [parentInvoiceId], references: [id])
  adjustments                  Invoice[]             @relation("InvoiceAdjustments")
  payments                     Payment[]
  lineItems                    InvoiceLineItem[]
  lockSnapshots                InvoiceLockSnapshot[]
  documentApplicationsAsSource DocumentApplication[] @relation("DocumentApplicationSource")
  documentApplicationsAsTarget DocumentApplication[] @relation("DocumentApplicationTarget")
  paymentAllocations           PaymentAllocation[]

  @@unique([id, financialCaseId])
  @@index([financialCaseId])
  @@index([jobId])
  @@index([jobNumber])
  @@map("invoices")
}

model InvoiceLockSnapshot {
  id              String      @id @default(cuid())
  invoiceId       String
  lockedAt        DateTime    @default(now())
  lockedByUserId  String?
  totalAmount     Decimal     @db.Decimal(10, 3)
  invoiceType     InvoiceType
  parentInvoiceId String?
  financialCaseId String
  jobId           String?
  orderId         String?
  invoiceNumber   String
  publicId        String

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, lockedAt])
  @@map("invoice_lock_snapshots")
}

model InvoiceLineItem {
  id                   String           @id @default(cuid())
  invoiceId            String
  lineType             InvoiceLineType
  description          String
  quantity             Int              @default(1)
  unitPrice            Decimal          @db.Decimal(10, 3)
  lineTotal            Decimal          @db.Decimal(10, 3)
  sortOrder            Int              @default(0)
  causeOrderEntityKind OrderEntityKind?
  causeOrderEntityId   String?
  createdAt            DateTime         @default(now())

  invoice              Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  documentApplications DocumentApplication[]

  @@unique([invoiceId, sortOrder])
  @@index([invoiceId])
  @@index([causeOrderEntityKind, causeOrderEntityId])
  @@map("invoice_line_items")
}

model Payment {
  id                String           @id @default(cuid())
  publicId          String           @unique
  financialCaseId   String
  jobNumber         String?
  jobId             String?
  invoiceId         String
  amount            Decimal          @db.Decimal(10, 3)
  direction         PaymentDirection @default(IN)
  method            PaymentMethod
  paymentType       PaymentType
  refundOfPaymentId String?
  paidAt            DateTime         @default(now())
  reference         String?
  notes             String?
  createdAt         DateTime         @default(now())

  financialCase   FinancialCase       @relation(fields: [financialCaseId], references: [id])
  job             Job?                @relation(fields: [jobId], references: [id])
  invoice         Invoice             @relation(fields: [invoiceId, financialCaseId], references: [id, financialCaseId])
  allocations     PaymentAllocation[]
  refundOfPayment Payment?            @relation("RefundsOfPayment", fields: [refundOfPaymentId], references: [id], onDelete: SetNull)
  refunds         Payment[]           @relation("RefundsOfPayment")

  @@index([invoiceId, financialCaseId])
  @@index([financialCaseId])
  @@index([jobId])
  @@index([jobNumber])
  @@index([refundOfPaymentId])
  @@map("payments")
}

model DocumentApplication {
  id                  String   @id @default(cuid())
  sourceInvoiceId     String   @map("source_invoice_id")
  targetInvoiceId     String   @map("target_invoice_id")
  targetInvoiceLineId String?  @map("target_invoice_line_id")
  amountApplied       Decimal  @map("amount_applied") @db.Decimal(10, 3)
  appliedAt           DateTime @default(now()) @map("applied_at")
  appliedByUserId     String?  @map("applied_by_user_id")
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")

  sourceInvoice     Invoice          @relation("DocumentApplicationSource", fields: [sourceInvoiceId], references: [id])
  targetInvoice     Invoice          @relation("DocumentApplicationTarget", fields: [targetInvoiceId], references: [id])
  targetInvoiceLine InvoiceLineItem? @relation(fields: [targetInvoiceLineId], references: [id], onDelete: SetNull)
  appliedBy         User?            @relation(fields: [appliedByUserId], references: [id], onDelete: SetNull)

  @@index([sourceInvoiceId])
  @@index([targetInvoiceId])
  @@index([targetInvoiceLineId])
  @@map("document_applications")
}

model PaymentAllocation {
  id        String   @id @default(cuid())
  paymentId String   @map("payment_id")
  invoiceId String   @map("invoice_id")
  amount    Decimal  @db.Decimal(10, 3)
  createdAt DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([paymentId])
  @@index([paymentId])
  @@index([invoiceId])
  @@map("payment_allocations")
}

model IdentifierSequence {
  scope     String
  year      Int
  kind      String   @default("JOB")
  lastValue Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([scope, year, kind])
  @@unique([scope, year, kind])
  @@map("identifier_sequences")
}
