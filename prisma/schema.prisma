generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  RECEPTIONIST
  RESERVATION
  PHOTOGRAPHER
  EDITOR
  ACCOUNTANT
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum SessionType {
  NEWBORN
  KIDS
  FAMILY
  MATERNITY
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum OrderStatus {
  ACTIVE
  WAITING_SELECTION
  EDITING
  PRODUCTION
  READY
  DELIVERED
  CANCELLED
}

enum OrderSelectionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum OrderEditingStatus {
  NOT_STARTED
  ASSIGNED
  IN_PROGRESS
  REVISION_REQUESTED
  AWAITING_APPROVAL
  APPROVED
  COMPLETED
}

enum OrderProductionStatus {
  NOT_STARTED
  WAITING_FOR_EDITING
  IN_PROGRESS
  WAITING_FOR_VENDOR
  READY_FOR_PICKUP
  COMPLETED
}

enum OrderProductionSectionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum OrderDeliveryStatus {
  NOT_READY
  READY_FOR_PICKUP
  CUSTOMER_NOTIFIED
  PICKED_UP
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  CLOSED
}

enum PaymentMethod {
  CASH
  KNET
  LINK
}

enum PaymentType {
  DEPOSIT
  BASE
  UPGRADE
  ADDON
  OTHER
}

enum OrderActivityType {
  ORDER_CREATED
  PACKAGE_CHANGED
  ADD_ON_CHANGED
  PAYMENT_RECEIVED
  INVOICE_ADJUSTED
  SELECTION_UPDATED
  SELECTION_COMPLETED
  EDITOR_ASSIGNED
  EDITING_STATUS_CHANGED
  PRODUCTION_STATUS_CHANGED
  DELIVERY_STATUS_CHANGED
  ORDER_COMPLETED
  NOTE_ADDED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      UserRole @default(RECEPTIONIST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedBookings      Booking[]       @relation("AssignedPhotographer")
  assignedEditingJobs   EditingJob[]    @relation("AssignedEditor")
  orderActivities       OrderActivity[]

  @@map("users")
}

model Customer {
  id        String         @id @default(cuid())
  name      String
  phone     String         @unique
  status    CustomerStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  children Child[]
  jobs     Job[]
  bookings Booking[]
  orders   Order[]
  invoices Invoice[]

  @@map("customers")
}

model Job {
  id         String   @id @default(cuid())
  jobNumber  String   @unique
  customerId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer  @relation(fields: [customerId], references: [id])
  booking  Booking?
  order    Order?
  editingJob EditingJob?
  invoices Invoice[]
  payments Payment[]

  @@index([customerId])
  @@map("jobs")
}

model Child {
  id          String    @id @default(cuid())
  name        String
  dateOfBirth DateTime?
  customerId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("children")
}

model Package {
  id          String  @id @default(cuid())
  name        String
  price       Decimal @db.Decimal(10, 3)
  photoCount  Int
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings       Booking[] @relation("BookingPackage")
  originalOrders Order[]   @relation("OriginalPackage")
  finalOrders    Order[]   @relation("FinalPackage")

  @@map("packages")
}

model OrderAddOnOption {
  id        String   @id @default(cuid())
  name      String
  category  String
  price     Decimal  @db.Decimal(10, 3)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, isActive])
  @@map("order_add_on_options")
}

model StudioDepartment {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@map("studio_departments")
}

model Booking {
  id                     String        @id @default(cuid())
  publicId               String        @unique
  jobNumber              String        @unique
  jobId                  String        @unique
  customerId             String
  packageId              String?
  sessionDate            DateTime
  sessionType            SessionType
  departmentId           String
  status                 BookingStatus @default(PENDING)
  assignedPhotographerId String?
  notes                  String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  job                  Job              @relation(fields: [jobId], references: [id])
  customer             Customer         @relation(fields: [customerId], references: [id])
  package              Package?         @relation("BookingPackage", fields: [packageId], references: [id])
  department           StudioDepartment @relation(fields: [departmentId], references: [id])
  assignedPhotographer User?            @relation("AssignedPhotographer", fields: [assignedPhotographerId], references: [id])
  order                Order?
  themes               BookingTheme[]
  invoices             Invoice[]

  @@unique([id, jobId])
  @@index([departmentId])
  @@map("bookings")
}

model BookingTheme {
  id        String   @id @default(cuid())
  bookingId String
  themeName String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_themes")
}

model Order {
  id                           String                       @id @default(cuid())
  publicId                     String                       @unique
  jobNumber                    String
  jobId                        String                       @unique
  bookingId                    String                       @unique
  // Intentional denormalization: duplicates Booking.customerId to allow direct
  // customer-scoped queries on orders without joining through bookings.
  customerId                   String
  originalPackageId            String?
  finalPackageId               String?
  selectedPhotoCount           Int?
  addOns                       Json                         @default("[]")
  status                       OrderStatus                  @default(ACTIVE)
  selectionStatus              OrderSelectionStatus         @default(PENDING)
  productionStatus             OrderProductionStatus        @default(NOT_STARTED)
  deliveryStatus               OrderDeliveryStatus          @default(NOT_READY)
  productionAlbumDesignStatus  OrderProductionSectionStatus @default(NOT_STARTED)
  productionPrintingStatus     OrderProductionSectionStatus @default(NOT_STARTED)
  productionAssemblyStatus     OrderProductionSectionStatus @default(NOT_STARTED)
  productionVendorStatus       OrderProductionSectionStatus @default(NOT_STARTED)
  productionFramedPrintsStatus OrderProductionSectionStatus @default(NOT_STARTED)
  productionFinalStatus        OrderProductionSectionStatus @default(NOT_STARTED)
  productionReadyAt            DateTime?
  deliveryPreparedAt           DateTime?
  customerNotifiedAt           DateTime?
  pickedUpAt                   DateTime?
  deliveryCompletedAt          DateTime?
  deliveryCompletedBy          String?
  deliveryPickupNotes          String?
  deliveryOverrideReason       String?
  nasFolderPath                String?
  notes                        String?
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt

  job             Job             @relation(fields: [jobId], references: [id])
  booking         Booking         @relation(fields: [bookingId, jobId], references: [id, jobId])
  customer        Customer        @relation(fields: [customerId], references: [id])
  editingJob      EditingJob?
  originalPackage Package?        @relation("OriginalPackage", fields: [originalPackageId], references: [id])
  finalPackage    Package?        @relation("FinalPackage", fields: [finalPackageId], references: [id])
  invoices        Invoice[]
  activities      OrderActivity[]

  @@unique([id, jobId])
  @@unique([bookingId, jobId])
  @@index([jobNumber])
  @@map("orders")
}

model EditingJob {
  id                           String                       @id @default(cuid())
  jobId                        String                       @unique
  orderId                      String                       @unique
  assignedEditorId             String?
  status                       OrderEditingStatus           @default(NOT_STARTED)
  editedPhotoCount             Int                          @default(0)
  revisionCount                Int                          @default(0)
  editingAssignedAt            DateTime?
  editingStartedAt             DateTime?
  editingCompletedAt           DateTime?
  customerApprovedAt           DateTime?
  sentToProductionAt           DateTime?
  estimatedEditingCompletionAt DateTime?
  notes                        String?
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt

  job            Job   @relation(fields: [jobId], references: [id])
  order          Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedEditor User? @relation("AssignedEditor", fields: [assignedEditorId], references: [id])

  @@index([jobId])
  @@index([assignedEditorId])
  @@map("editing_jobs")
}

model OrderActivity {
  id          String            @id @default(cuid())
  orderId     String
  userId      String?
  type        OrderActivityType
  title       String
  description String?
  metadata    Json              @default("{}")
  createdAt   DateTime          @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([type])
  @@map("order_activities")
}

model Invoice {
  id              String        @id @default(cuid())
  publicId        String        @unique
  jobNumber       String
  jobId           String
  orderId         String?
  bookingId       String?
  customerId      String
  invoiceSeq      Int           @unique @default(dbgenerated("nextval('\"invoice_number_seq\"'::regclass)"))
  invoiceNumber   String        @unique
  totalAmount     Decimal       @db.Decimal(10, 3)
  paidAmount      Decimal       @default(0) @db.Decimal(10, 3)
  remainingAmount Decimal       @default(0) @db.Decimal(10, 3)
  status          InvoiceStatus @default(DRAFT)
  isLocked        Boolean       @default(false)
  parentInvoiceId String?
  notes           String?
  issuedAt        DateTime?
  closedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  job           Job       @relation(fields: [jobId], references: [id])
  order         Order?    @relation(fields: [orderId, jobId], references: [id, jobId])
  booking       Booking?  @relation(fields: [bookingId, jobId], references: [id, jobId])
  customer      Customer  @relation(fields: [customerId], references: [id])
  parentInvoice Invoice?  @relation("InvoiceAdjustments", fields: [parentInvoiceId], references: [id])
  adjustments   Invoice[] @relation("InvoiceAdjustments")
  payments      Payment[]

  @@unique([id, jobId])
  @@index([jobId])
  @@index([jobNumber])
  @@map("invoices")
}

model Payment {
  id          String        @id @default(cuid())
  publicId    String        @unique
  jobNumber   String
  jobId       String
  invoiceId   String
  amount      Decimal       @db.Decimal(10, 3)
  method      PaymentMethod
  paymentType PaymentType
  paidAt      DateTime      @default(now())
  reference   String?
  notes       String?
  createdAt   DateTime      @default(now())

  job     Job     @relation(fields: [jobId], references: [id])
  invoice Invoice @relation(fields: [invoiceId, jobId], references: [id, jobId])

  @@index([jobId])
  @@index([jobNumber])
  @@map("payments")
}

model IdentifierSequence {
  scope     String
  year      Int
  lastValue Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([scope, year])
  @@map("identifier_sequences")
}
